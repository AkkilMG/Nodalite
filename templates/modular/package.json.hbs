{
  "name": "{{projectName}}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsup src/server.ts --format esm --dts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "nodalite": "latest"{{#if security}},
    "@nodalite/middleware": "latest"{{/if}}
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
