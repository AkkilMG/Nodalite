{
  "name": "nodalite-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Runtime-agnostic TypeScript API framework — runs on Node, Lambda, Cloudflare Workers, Bun, Deno.",
  "type": "module",
  "keywords": ["monorepo", "api", "framework", "typescript", "runtime-agnostic", "serverless", "worker", "ml"],
  "license": "MIT",
  "author": "Akkil <me@akkil.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkkilMG/Nodalite.git"
  },
  "bugs": {
    "url": "https://github.com/AkkilMG/Nodalite/issues"
  },
  "homepage": "https://github.com/AkkilMG/Nodalite#readme",
  "engines": {
    "node": ">=18"
  },
  "workspaces": ["packages/*", "examples/*", "docs"],
  "scripts": {
    "prepare": "npm run build --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "changeset": "changeset",
    "release": "npm run build --workspaces --if-present && changeset publish",
    "dev:basic": "npm run dev -w examples-basic-api"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsup": "^8.3.5",
    "vitest": "^2.1.4",
    "@changesets/cli": "^2.27.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "@eslint/js": "^9.15.0",
    "typescript-eslint": "^8.16.0",
    "globals": "^15.0.0"
  }
}
