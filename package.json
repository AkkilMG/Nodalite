{
  "name": "nodalite",
  "version": "0.1.2",
  "description": "Runtime-agnostic TypeScript API framework — runs on Node, Lambda, Cloudflare Workers, Bun, Deno.",
  "type": "module",
  "keywords": ["monorepo", "api", "framework", "typescript", "runtime-agnostic", "serverless", "worker", "ml"],
  "license": "MIT",
  "author": "Akkil <me@akkil.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkkilMG/Nodalite.git"
  },
  "bugs": {
    "url": "https://github.com/AkkilMG/Nodalite/issues"
  },
  "homepage": "https://github.com/AkkilMG/Nodalite#readme",
  "engines": {
    "node": ">=18"
  },
  "workspaces": ["packages/*", "examples/*", "docs"],
  "scripts": {
    "build": "npm run build -w @nodalite/core && npm run build --workspaces --if-present",
    "test": "vitest run",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "changeset": "changeset",
    "release": "npm run build --workspaces --if-present && changeset publish",
    "dev:basic": "npm run dev -w examples-basic-api",
    "dev:security": "npm run dev -w examples-security-api"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "tsup": "^8.5.1",
    "vitest": "^4.0.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.0.0",
    "eslint": "^10.0.0",
    "@eslint/js": "^10.0.0",
    "typescript-eslint": "^8.63.0",
    "globals": "^17.0.0"
  }
}
