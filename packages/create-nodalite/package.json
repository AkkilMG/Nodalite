{
  "name": "create-nodalite",
  "version": "0.1.0",
  "license": "MIT",
  "keywords": ["scaffold", "cli", "generator", "template", "create-app"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkkilMG/Nodalite.git",
    "directory": "packages/create-nodalite"
  },
  "bugs": {
    "url": "https://github.com/AkkilMG/Nodalite/issues"
  },
  "homepage": "https://nodalite.akkil.dev",
  "description": "Scaffold a new Nodalite project — interactive CLI to generate APIs, Telegram bots, Lambda functions, and edge workers.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "create-nodalite": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean --minify && node -e \"const{cpSync}=require('node:fs');const{join}=require('node:path');cpSync(join(process.cwd(),'../../templates'),join(process.cwd(),'dist/templates'),{recursive:true})\"",
    "dev": "tsup src/cli.ts --format esm --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "citty": "^0.2.0",
    "consola": "^3.4.2",
    "handlebars": "^4.7.9",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0"
  }
}
