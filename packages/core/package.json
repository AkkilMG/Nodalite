{
  "name": "@nodalite/core",
  "version": "0.1.0",
  "license": "MIT",
  "keywords": ["router", "middleware", "context", "fetch-api", "typescript", "runtime-agnostic", "serverless"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkkilMG/Nodalite.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/AkkilMG/Nodalite/issues"
  },
  "description": "Tiny, runtime-agnostic router + context + middleware engine for Nodalite. Built on the standard Fetch Request/Response API so it works identically on Node, Bun, Deno, Workers and Lambda.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --minify",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
