{
  "name": "@nodalite/adapter-node",
  "version": "0.1.0",
  "license": "MIT",
  "keywords": ["node", "http", "server", "adapter", "fetch-api", "runtime-agnostic"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkkilMG/Nodalite.git",
    "directory": "packages/adapter-node"
  },
  "bugs": {
    "url": "https://github.com/AkkilMG/Nodalite/issues"
  },
  "description": "Run a Nodalite App on a plain Node.js http/https server.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nodalite/core": "*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "@types/node": "^22.9.0"
  }
}
