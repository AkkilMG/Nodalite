{
  "name": "@nodalite/middleware",
  "version": "0.1.0",
  "license": "MIT",
  "keywords": ["cors", "security-headers", "rate-limit", "jwt", "middleware", "http", "security"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkkilMG/Nodalite.git",
    "directory": "packages/middleware"
  },
  "bugs": {
    "url": "https://github.com/AkkilMG/Nodalite/issues"
  },
  "description": "Batteries-included security & HTTP middleware for Nodalite: CORS, security headers, rate limiting, and JWT auth.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nodalite/core": "*",
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
