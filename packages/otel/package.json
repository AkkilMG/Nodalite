{
  "name": "@nodalite/otel",
  "version": "0.1.0",
  "license": "MIT",
  "keywords": [
    "opentelemetry",
    "otel",
    "tracing",
    "metrics",
    "observability",
    "apm",
    "monitoring"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkkilMG/Nodalite.git",
    "directory": "packages/otel"
  },
  "bugs": {
    "url": "https://github.com/AkkilMG/Nodalite/issues"
  },
  "description": "OpenTelemetry integration for Nodalite: built-in tracing, metrics, and context propagation for production observability.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify",
    "test": "vitest run",
    "typecheck": "tsc -b tsconfig.build.json"
  },
  "dependencies": {
    "@nodalite/core": "*",
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
