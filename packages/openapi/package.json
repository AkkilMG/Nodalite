{
  "name": "@nodalite/openapi",
  "version": "0.1.0",
  "license": "MIT",
  "keywords": [
    "openapi",
    "swagger",
    "redoc",
    "api-docs",
    "documentation",
    "zod",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkkilMG/Nodalite.git",
    "directory": "packages/openapi"
  },
  "bugs": {
    "url": "https://github.com/AkkilMG/Nodalite/issues"
  },
  "description": "OpenAPI spec generation + Swagger UI + ReDoc for Nodalite. Auto-document your API, just like FastAPI.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nodalite/core": "*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0",
    "zod": "*"
  },
  "peerDependencies": {
    "zod": "^3.25.28 || ^4"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  }
}
